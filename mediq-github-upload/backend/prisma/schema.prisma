generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Since SQLite does not support ENUM, we can just use String with application-level validation
// but Prisma with SQLite can still simulate enums if we use strings, or we just use simple Strings.
// Actually Prisma doesn't support Enums natively in SQLite. Let's use simple Strings.

model User {
  id             String         @id @default(uuid())
  phone          String         @unique
  email          String?        @unique
  passwordHash   String?
  role           String         @default("PATIENT") // ADMIN, DOCTOR, RECEPTIONIST, PATIENT
  firstName      String
  lastName       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  appointments   Appointment[]
  notifications  Notification[]
}

model PatientProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  age       Int?
  gender    String?
  bloodType String?
}

model DoctorProfile {
  id           String      @id @default(uuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id])
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  specialization String?
  available    Boolean     @default(true)
  appointments Appointment[]
}

model Department {
  id          String          @id @default(uuid())
  name        String          @unique
  code        String          @unique // e.g., GM, OR
  doctors     DoctorProfile[]
  appointments Appointment[]
}

model Appointment {
  id            String            @id @default(uuid())
  patientId     String
  patient       User              @relation(fields: [patientId], references: [id])
  doctorId      String?
  doctor        DoctorProfile?    @relation(fields: [doctorId], references: [id])
  departmentId  String
  department    Department        @relation(fields: [departmentId], references: [id])
  
  reason        String
  symptoms      String?
  
  preferredDate DateTime
  preferredTime String? // e.g., "10:30"
  
  status        String            @default("PENDING") // PENDING, APPROVED, IN_QUEUE, COMPLETED, MISSED, CANCELLED
  priority      String            @default("NORMAL") // LOW, NORMAL, HIGH, EMERGENCY
  
  tokenNumber   String? // e.g., GM-051
  queuePosition Int?
  estimatedWait Int? // in minutes
  
  attachmentUrl String? // Medical file upload path
  pharmacyStatus String? // PENDING, DISPENSED
  
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  queueLogs     QueueLog[]
}

model QueueLog {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  status        String
  notes         String?
  createdAt     DateTime    @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // SMS, PUSH, EMAIL
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
